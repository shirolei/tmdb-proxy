{
    "version": 2,
    "functions": {
        "api/**/*.js": {
            "runtime": "@vercel/node@3"
        }
    },
    "redirects": [
        {
            "source": "/",
            "destination": "https://github.com/imaliang/tmdb-proxy",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/tmdb.js"
        },
        {
            "source": "/t/p/:path*",
            "destination": "https://image.tmdb.org/t/p/:path*"
        }
    ]
}
